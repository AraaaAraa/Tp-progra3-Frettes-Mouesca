<%- include("reutilizables/head.ejs") %> 
<%- include("reutilizables/nav.ejs") %> 

<main>
    <h2>Agregar Nuevo Juego / Producto</h2>
    <form id="form-crear-producto">
        <label for="nombre">Nombre del producto:</label>
        <input type="text" id="nombre" name="nombre" required>

        <label for="precio">Precio ($):</label>
        <input type="number" id="precio" name="precio" required>

        <label for="imagen">URL de la Imagen:</label>
        <input type="url" id="imagen" name="imagen" required>

        <label for="tipo">Tipo:</label>
        <input type="text" id="tipo" name="tipo" required>

        <label for="descripcion">Descripción:</label>
        <input type="text" id="descripcion" name="descripcion" required>

        <button type="submit">Guardar en Base de Datos</button>
    </form>

    <div id="status-message"></div>
</main>

<script src="/js/dashboard-crear.js"></script>

</body>
</html>